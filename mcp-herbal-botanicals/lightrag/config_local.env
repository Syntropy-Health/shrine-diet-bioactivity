# LightRAG — Local Development Config (Ollama)
# Uses local Ollama models for embedding + LLM (zero API cost)
# Neo4j on Railway test instance

# Server
HOST=0.0.0.0
PORT=9621

# LLM — Ollama local
LLM_BINDING=ollama
LLM_BINDING_HOST=http://localhost:11434
LLM_MODEL=qwen3.5:9b
OLLAMA_LLM_NUM_CTX=32768

# Embedding — Ollama local
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024
OLLAMA_EMBEDDING_NUM_CTX=8192

# Storage — Neo4j graph + local file KV/vector
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
WORKING_DIR=./rag_storage_local

# Neo4j — Railway test instance
NEO4J_URI=bolt://metro.proxy.rlwy.net:22971
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=demodemo
NEO4J_DATABASE=neo4j

# Workspace isolation (avoids collision with old Graphiti data)
WORKSPACE=unified_diet_kg

# Domain entity types for extraction (used when ingesting text, not custom KG)
ENTITY_TYPES='["Herb","Compound","Food","Target","Disease","Symptom","Nutrient"]'
SUMMARY_LANGUAGE=English

# Concurrency
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2

# Reranking — disabled for local dev
RERANK_BINDING=null

# Query defaults
TOP_K=40
CHUNK_TOP_K=20
MAX_TOTAL_TOKENS=30000

# Cache
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
